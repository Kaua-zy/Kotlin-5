// click the <icon src="AllIcons.Actions.Execute"/> icon in the gutter.
fun main() {
    inicio()
}

fun inicio() {
    var saldo = 1000.0

    print("Digite seu nome: ")
    val nome = readLine() ?: "Usuário"

    println("Olá $nome, é um prazer ter você por aqui!")

    while (true) {
        println("\nSaldo atual: R$ $saldo")
        println("1 - Sacar")
        println("2 - Sair")

        print("Escolha uma opção: ")
        val opcao = readLine()

        when (opcao) {
            "1" -> {
                print("Digite o valor para saque: ")
                val valor = readLine()?.toDoubleOrNull()

                if (valor == null) {
                    println("Valor inválido!")
                } else if (valor > saldo) {
                    println("Operação não autorizada")
                } else {
                    saldo -= valor
                    println("Saque realizado com sucesso!")
                }
            }

            "2" -> {
                println("Até mais, $nome!")
                break
            }

            else -> {
                println("Opção inválida!")
            }
        }
    }
}


